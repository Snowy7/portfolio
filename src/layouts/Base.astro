---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: "website" | "article";
  article?: {
    publishedTime?: string;
    tags?: string[];
  };
}

const siteUrl = "https://islamazzam.dev";
const defaultDescription = "Islam Azzam — Software Developer & Network Engineer. 8+ years building web platforms, multiplayer games, AI tools, and autonomous vehicles.";
const defaultImage = `${siteUrl}/images/me/linkedin-pfp.png`;

const {
  title,
  description = defaultDescription,
  image = defaultImage,
  url,
  type = "website",
  article,
} = Astro.props;

const canonicalUrl = url || new URL(Astro.url.pathname, siteUrl).href;
const fullImageUrl = image.startsWith("http") ? image : `${siteUrl}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Islam Azzam" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Theme -->
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Islam Azzam" />
    <meta property="og:locale" content="en_US" />
    {article?.publishedTime && (
      <meta property="article:published_time" content={article.publishedTime} />
    )}
    {article?.tags?.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@snowy7x" />
    <meta name="twitter:creator" content="@snowy7x" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anybody:wght@100..900&family=IBM+Plex+Mono:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- View Transitions (SPA-like navigation) -->
    <ClientRouter />

    <!-- JSON-LD Structured Data -->
    {type === "website" ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Islam Azzam",
        alternateName: "Snowy7",
        url: siteUrl,
        image: defaultImage,
        jobTitle: "Software Developer & Network Engineer",
        worksFor: { "@type": "Organization", name: "Limeless Inc." },
        alumniOf: {
          "@type": "CollegeOrUniversity",
          name: "University of Doha for Science and Technology",
        },
        knowsAbout: ["Web Development", "Game Development", "Autonomous Systems", "Network Engineering"],
        sameAs: [
          "https://github.com/Snowy7",
          "https://www.linkedin.com/in/islam-azzam-6a3449205/",
          "https://twitter.com/snowy7x",
          "https://snowy7.itch.io",
        ],
        address: {
          "@type": "PostalAddress",
          addressLocality: "Doha",
          addressCountry: "QA",
        },
      })} />
    ) : type === "article" ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title.replace(" | Islam Azzam", ""),
        description,
        image: fullImageUrl,
        url: canonicalUrl,
        datePublished: article?.publishedTime,
        author: {
          "@type": "Person",
          name: "Islam Azzam",
          url: siteUrl,
        },
        publisher: {
          "@type": "Person",
          name: "Islam Azzam",
          url: siteUrl,
        },
        keywords: article?.tags?.join(", "),
      })} />
    ) : null}
  </head>
  <body>
    <!-- Loading bar for page transitions -->
    <div id="nav-loading-bar"></div>

    <slot />

    <!-- Scroll reveal observer + loading bar logic -->
    <script>
      function initReveal() {
        const els = document.querySelectorAll('.reveal:not(.revealed)');
        if (!els.length) return;
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('revealed');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        els.forEach((el) => obs.observe(el));
      }

      // Run on initial load
      initReveal();

      // Re-run after view transition swap
      document.addEventListener('astro:page-load', () => {
        initReveal();
      });

      // Loading bar
      const bar = document.getElementById('nav-loading-bar');
      document.addEventListener('astro:before-preparation', () => {
        if (bar) { bar.classList.add('active'); }
      });
      document.addEventListener('astro:after-swap', () => {
        if (bar) {
          bar.classList.remove('active');
          bar.style.transform = '';
        }
      });
    </script>
  </body>
</html>
