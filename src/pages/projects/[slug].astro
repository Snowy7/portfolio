---
import Base from "../../layouts/Base.astro";
import { projects } from "../../data/portfolio";
import AppShell from "../../components/AppShell.vue";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Base
  title={`${project.title} | Islam Azzam`}
  description={project.description}
  image={project.image}
>
  <div class="min-h-screen bg-black text-[#999] font-plex antialiased selection:bg-green-500/20 selection:text-green-300">
    <AppShell client:only="vue">

      <article class="pt-20 sm:pt-24 pb-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-3xl mx-auto">

          <!-- Back -->
          <a href="/projects" data-animate="boot-1" class="inline-flex items-center gap-2 text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            ALL PROJECTS
          </a>

          <!-- Header -->
          <div data-animate="boot-2" class="mb-8">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[9px] tracking-wider uppercase px-2 py-0.5 border border-green-400/20 text-green-400/50 rounded">{project.category}</span>
              <span class="text-[10px] text-[#444]">{project.status}</span>
            </div>
            <h1 class="font-anybody font-800 text-3xl sm:text-4xl leading-tight tracking-tight text-white mb-3">
              {project.title}
            </h1>
            <div class="flex items-center flex-wrap gap-4 text-[10px] text-[#666]">
              <span>{project.role}</span>
              <span class="text-[#333]">&middot;</span>
              <span>{project.year}</span>
              {project.duration && (
                <>
                  <span class="text-[#333]">&middot;</span>
                  <span>{project.duration}</span>
                </>
              )}
            </div>
          </div>

          <!-- Cover Image -->
          <div data-animate="boot-3" class="rounded-xl overflow-hidden border border-[#1a1a1a] mb-8">
            <img
              src={project.image}
              alt={project.title}
              class="w-full aspect-video object-cover"
            />
          </div>

          <!-- Links -->
          {project.links.length > 0 && (
            <div class="flex gap-3 mb-8">
              {project.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 px-4 py-2 bg-green-400/10 border border-green-400/20 rounded-lg text-green-400 text-xs tracking-wider hover:bg-green-400/20 hover:border-green-400/40 transition-all"
                >
                  {link.label}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ))}
            </div>
          )}

          <!-- Description -->
          <div class="mb-10">
            <p class="text-sm text-[#bbb] leading-relaxed">
              {project.longDescription || project.description}
            </p>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2 mb-10">
            {project.tags.map((tag) => (
              <span class="text-[10px] tracking-wider uppercase text-[#555] px-2.5 py-1 border border-[#1a1a1a] rounded">{tag}</span>
            ))}
          </div>

          <!-- Highlights -->
          {project.highlights && project.highlights.length > 0 && (
            <div class="reveal mb-10">
              <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-4">Highlights</p>
              <ul class="space-y-2">
                {project.highlights.map((h) => (
                  <li class="flex items-start gap-3 text-xs text-[#888] leading-relaxed">
                    <span class="text-green-400/40 shrink-0 mt-0.5">&rarr;</span>
                    {h}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Gallery -->
          {project.gallery && project.gallery.length > 0 && (
            <div class="reveal mb-10">
              <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-4">Gallery</p>
              <div class="grid sm:grid-cols-2 gap-3">
                {project.gallery.map((img) => (
                  <div class="rounded-lg overflow-hidden border border-[#1a1a1a]">
                    <img src={img} alt={project.title} class="w-full aspect-video object-cover" loading="lazy" />
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Navigation -->
          <div class="pt-8 border-t border-[#1a1a1a] flex justify-between items-center">
            <a href="/projects" class="text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider">
              &larr; All projects
            </a>
            <a href="/#contact" class="text-[10px] text-green-400/50 hover:text-green-400 transition-colors tracking-wider">
              Work with me &rarr;
            </a>
          </div>

        </div>
      </article>

      <footer class="py-6 px-4 sm:px-6 border-t border-[#1a1a1a] relative z-10">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2 text-[10px] text-[#555]">
          <p>&copy; 2026 Islam Azzam</p>
          <a href="/" class="hover:text-[#999] transition-colors">Back to home</a>
        </div>
      </footer>

    </AppShell>
  </div>

</Base>
