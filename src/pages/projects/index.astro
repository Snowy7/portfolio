---
import Base from "../../layouts/Base.astro";
import { projects, skills, skillCategories } from "../../data/portfolio";
import AppShell from "../../components/AppShell.vue";

const categories = [
  { id: "web", label: "Web", accent: "text-green-400" },
  { id: "mobile", label: "Mobile", accent: "text-blue-400" },
  { id: "game", label: "Games", accent: "text-purple-400" },
  { id: "engineering", label: "Engineering", accent: "text-amber-400" },
];

const grouped = categories.map(cat => ({
  ...cat,
  items: projects.filter(p => p.category === cat.id),
})).filter(g => g.items.length > 0);
---

<Base
  title="Projects | Islam Azzam"
  description="A selection of projects by Islam Azzam — from AI platforms and multiplayer games to autonomous vehicles and mobile apps."
>
  <div class="min-h-screen bg-black text-[#999] font-plex antialiased selection:bg-green-500/20 selection:text-green-300">
    <AppShell client:only="vue">

      <!-- Header -->
      <section class="pt-20 sm:pt-24 pb-8 sm:pb-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <a href="/" class="inline-flex items-center gap-2 text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            BACK HOME
          </a>
          <h1 class="font-anybody font-800 text-3xl sm:text-4xl md:text-5xl leading-[0.9] tracking-tight text-white mb-4">
            Projects<span class="text-green-400">.</span>
          </h1>
          <p class="text-sm text-[#777] leading-relaxed max-w-lg">
            From AI platforms and multiplayer games to autonomous vehicles — a selection of what I've built.
          </p>
        </div>
      </section>

      <!-- Projects by Category -->
      {grouped.map((group) => (
        <section class="pb-10 sm:pb-12 px-4 sm:px-6 relative z-10">
          <div class="max-w-4xl mx-auto">
            <div class="flex items-center gap-3 mb-4">
              <p class={`text-[10px] tracking-[0.3em] uppercase ${group.accent}/50`}>{group.label}</p>
              <div class="flex-1 h-px bg-[#1a1a1a]"></div>
              <span class="text-[10px] text-[#333]">{group.items.length}</span>
            </div>

            <div class="space-y-1">
              {group.items.map((project, i) => (
                <a href={`/projects/${project.slug}`} class="group block">
                  <article class="flex items-start gap-4 py-4 border-b border-[#111] hover:border-[#222] transition-colors">
                    <!-- Thumbnail -->
                    <div class="hidden sm:block w-[120px] shrink-0 overflow-hidden rounded-md">
                      <img
                        src={project.image}
                        alt={project.title}
                        class="w-full aspect-[16/10] object-cover opacity-25 grayscale group-hover:opacity-50 group-hover:grayscale-0 transition-all duration-500"
                        loading="lazy"
                      />
                    </div>
                    <!-- Content -->
                    <div class="flex-1 min-w-0">
                      <div class="flex items-baseline gap-2 mb-1">
                        <h2 class="text-sm text-white font-bold group-hover:text-green-400 transition-colors truncate">{project.title}</h2>
                        <span class="text-[10px] text-[#444] shrink-0">{project.year}</span>
                      </div>
                      <p class="text-xs text-[#666] leading-relaxed mb-2 line-clamp-2">{project.description}</p>
                      <div class="flex items-center gap-2 flex-wrap">
                        {project.tags.slice(0, 4).map((tag) => (
                          <span class="text-[9px] tracking-wider uppercase text-[#444] px-1.5 py-0.5 border border-[#1a1a1a] rounded">{tag}</span>
                        ))}
                        <div class="flex-1"></div>
                        <div class="flex items-center gap-2 shrink-0">
                          {project.links.length > 0 && (
                            <span class="text-[9px] text-green-400/40 tracking-wider uppercase">{project.links[0].label}</span>
                          )}
                          <span class="text-[9px] text-[#333] tracking-wider">{project.status}</span>
                        </div>
                      </div>
                    </div>
                    <!-- Arrow -->
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#222] group-hover:text-green-400/50 transition-colors shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </article>
                </a>
              ))}
            </div>
          </div>
        </section>
      ))}

      <!-- Skills -->
      <section class="py-10 sm:py-12 px-4 sm:px-6 relative z-10 border-t border-[#1a1a1a]">
        <div class="max-w-4xl mx-auto">
          <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-8">Tech stack</p>
          <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
            {skillCategories.map((cat) => (
              <div>
                <p class="text-[10px] tracking-wider uppercase text-[#555] mb-3">{cat}</p>
                <div class="space-y-2">
                  {skills.filter((s) => s.category === cat).map((skill) => (
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-[#999]">{skill.name}</span>
                      <div class="flex gap-0.5">
                        {Array.from({ length: 10 }).map((_, j) => (
                          <div
                            class:list={[
                              "w-1.5 h-1.5 rounded-sm",
                              j < Math.round(skill.level / 10)
                                ? "bg-green-400/50"
                                : "bg-[#1a1a1a]",
                            ]}
                          />
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-12 sm:py-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-sm text-[#777] mb-4">Interested in working together?</p>
          <a href="/#contact" class="inline-block px-6 py-3 bg-green-400/10 border border-green-400/20 rounded-lg text-green-400 text-xs font-bold tracking-wider hover:bg-green-400/20 hover:border-green-400/40 transition-all">
            GET IN TOUCH
          </a>
        </div>
      </section>

      <footer class="py-6 px-4 sm:px-6 border-t border-[#1a1a1a] relative z-10">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2 text-[10px] text-[#555]">
          <p>&copy; 2026 Islam Azzam</p>
          <a href="/" class="hover:text-[#999] transition-colors">Back to home</a>
        </div>
      </footer>

    </AppShell>
  </div>
</Base>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
