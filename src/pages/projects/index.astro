---
import Base from "../../layouts/Base.astro";
import { projects, skills, skillCategories } from "../../data/portfolio";
import AppShell from "../../components/AppShell.vue";
---

<Base title="Islam | Projects">
  <div class="min-h-screen bg-black text-[#999] font-plex antialiased selection:bg-green-500/20 selection:text-green-300">
    <AppShell client:only="vue">

      <!-- Header -->
      <section class="pt-20 sm:pt-24 pb-8 sm:pb-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <a href="/" class="inline-flex items-center gap-2 text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            BACK HOME
          </a>
          <h1 class="font-anybody font-800 text-3xl sm:text-4xl md:text-5xl leading-[0.9] tracking-tight text-white mb-4">
            Projects<span class="text-green-400">.</span>
          </h1>
          <p class="text-sm text-[#777] leading-relaxed max-w-lg">
            A selection of things I've built. From real-time dashboards to e-commerce platforms — each one taught me something new.
          </p>
        </div>
      </section>

      <!-- All Projects -->
      <section class="pb-12 sm:pb-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <div class="grid sm:grid-cols-2 gap-4">
            {projects.map((project, i) => (
              <article class="group bg-[#0a0a0a] border border-[#1a1a1a] rounded-xl overflow-hidden hover:border-[#2a2a2a] transition-all duration-500">
                <div class="overflow-hidden">
                  <img
                    src={project.image}
                    alt={project.title}
                    class="w-full aspect-video object-cover opacity-20 grayscale group-hover:opacity-45 group-hover:grayscale-0 transition-all duration-700"
                    loading="lazy"
                  />
                </div>
                <div class="p-4 sm:p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-[10px] text-green-400/30">0{i + 1}</span>
                    <h2 class="text-sm text-white font-bold group-hover:text-green-400 transition-colors">{project.title}</h2>
                  </div>
                  <p class="text-xs text-[#777] leading-relaxed mb-3">{project.description}</p>
                  <div class="flex flex-wrap gap-1.5 mb-4">
                    {project.tags.map((tag) => (
                      <span class="text-[9px] tracking-wider uppercase text-[#555] px-2 py-0.5 border border-[#1a1a1a] rounded">{tag}</span>
                    ))}
                  </div>
                  <div class="flex gap-4 text-[10px] tracking-wider">
                    <a href={project.link} class="text-green-400/50 hover:text-green-400 transition-colors">LIVE DEMO</a>
                    <a href={project.github} class="text-[#555] hover:text-white transition-colors">SOURCE CODE</a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Skills -->
      <section class="py-10 sm:py-12 px-4 sm:px-6 relative z-10 border-t border-[#1a1a1a]">
        <div class="max-w-4xl mx-auto">
          <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-8">Tech stack</p>
          <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6">
            {skillCategories.map((cat) => (
              <div>
                <p class="text-[10px] tracking-wider uppercase text-[#555] mb-3">{cat}</p>
                <div class="space-y-2">
                  {skills.filter((s) => s.category === cat).map((skill) => (
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-[#999]">{skill.name}</span>
                      <div class="flex gap-0.5">
                        {Array.from({ length: 10 }).map((_, j) => (
                          <div
                            class:list={[
                              "w-1.5 h-1.5 rounded-sm",
                              j < Math.round(skill.level / 10)
                                ? "bg-green-400/50"
                                : "bg-[#1a1a1a]",
                            ]}
                          />
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="py-12 sm:py-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <p class="text-sm text-[#777] mb-4">Interested in working together?</p>
          <a href="/#contact" class="inline-block px-6 py-3 bg-green-400/10 border border-green-400/20 rounded-lg text-green-400 text-xs font-bold tracking-wider hover:bg-green-400/20 hover:border-green-400/40 transition-all">
            GET IN TOUCH
          </a>
        </div>
      </section>

      <footer class="py-6 px-4 sm:px-6 border-t border-[#1a1a1a] relative z-10">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2 text-[10px] text-[#555]">
          <p>&copy; 2026 Islam</p>
          <a href="/" class="hover:text-[#999] transition-colors">Back to home</a>
        </div>
      </footer>

    </AppShell>
  </div>
</Base>
