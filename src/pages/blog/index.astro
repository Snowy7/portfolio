---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import AppShell from "../../components/AppShell.vue";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.published)
  .sort((a, b) => {
    // Sort newest first by parsing "Mon YYYY" dates
    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    const parse = (d: string) => {
      const [mon, yr] = d.split(" ");
      return parseInt(yr) * 12 + months.indexOf(mon);
    };
    return parse(b.data.date) - parse(a.data.date);
  });
---

<Base
  title="Blog | Islam Azzam"
  description="Thoughts on game dev, web platforms, autonomous systems, and the things I learn along the way."
>
  <div class="min-h-screen bg-black text-[#999] font-plex antialiased selection:bg-green-500/20 selection:text-green-300">
    <AppShell client:only="vue">

      <!-- Header -->
      <section class="pt-20 sm:pt-24 pb-8 sm:pb-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-3xl mx-auto">
          <a href="/" class="inline-flex items-center gap-2 text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            BACK HOME
          </a>
          <h1 class="font-anybody font-800 text-3xl sm:text-4xl md:text-5xl leading-[0.9] tracking-tight text-white mb-4">
            Blog<span class="text-green-400">.</span>
          </h1>
          <p class="text-sm text-[#777] leading-relaxed max-w-lg">
            Thoughts on game dev, web platforms, autonomous systems, and the things I learn along the way.
          </p>
        </div>
      </section>

      <!-- Posts -->
      <section class="pb-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-3xl mx-auto space-y-1">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="group block">
              <article class="py-6 border-b border-[#111] hover:border-[#222] transition-colors">
                <div class="flex items-center gap-3 text-[10px] text-[#555] mb-2">
                  <span>{post.data.date}</span>
                  <span>&middot;</span>
                  <span>{post.data.readTime}</span>
                  <div class="flex-1"></div>
                  {post.data.tags.map((tag) => (
                    <span class="text-[9px] tracking-wider uppercase text-[#444] px-1.5 py-0.5 border border-[#1a1a1a] rounded">{tag}</span>
                  ))}
                </div>
                <h2 class="text-base text-white font-bold mb-2 group-hover:text-green-400 transition-colors">{post.data.title}</h2>
                <p class="text-xs text-[#777] leading-relaxed">{post.data.excerpt}</p>
              </article>
            </a>
          ))}
        </div>
      </section>

      <footer class="py-6 px-4 sm:px-6 border-t border-[#1a1a1a] relative z-10">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2 text-[10px] text-[#555]">
          <p>&copy; 2026 Islam Azzam</p>
          <a href="/" class="hover:text-[#999] transition-colors">Back to home</a>
        </div>
      </footer>

    </AppShell>
  </div>
</Base>
