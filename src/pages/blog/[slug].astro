---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import AppShell from "../../components/AppShell.vue";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((p) => p.data.published)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={`${post.data.title} | Islam Azzam`}
  description={post.data.excerpt}
  type="article"
  article={{ publishedTime: post.data.date, tags: post.data.tags }}
>
  <div class="min-h-screen bg-black text-[#999] font-plex antialiased selection:bg-green-500/20 selection:text-green-300">
    <AppShell client:only="vue">

      <article class="pt-20 sm:pt-24 pb-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-3xl mx-auto">

          <!-- Back -->
          <a href="/blog" class="boot-stagger-1 inline-flex items-center gap-2 text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            ALL POSTS
          </a>

          <!-- Header -->
          <header class="boot-stagger-2 mb-10">
            <div class="flex items-center gap-3 text-[10px] text-[#555] mb-4">
              <span>{post.data.date}</span>
              <span>&middot;</span>
              <span>{post.data.readTime}</span>
            </div>
            <h1 class="font-anybody font-800 text-2xl sm:text-3xl md:text-4xl leading-tight tracking-tight text-white mb-4">
              {post.data.title}
            </h1>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-[9px] tracking-wider uppercase text-[#555] px-2 py-0.5 border border-[#1a1a1a] rounded">{tag}</span>
              ))}
            </div>
          </header>

          <!-- Content -->
          <div class="boot-stagger-3 prose-terminal">
            {post.body && post.body.trim().length > 0 ? (
              <Content />
            ) : (
              <p class="text-sm text-[#555] italic">No content yet. Check back soon.</p>
            )}
          </div>

          <!-- Navigation -->
          <div class="pt-10 mt-10 border-t border-[#1a1a1a] flex justify-between items-center">
            <a href="/blog" class="text-[10px] text-[#555] hover:text-green-400 transition-colors tracking-wider">
              &larr; All posts
            </a>
            <a href="/#contact" class="text-[10px] text-green-400/50 hover:text-green-400 transition-colors tracking-wider">
              Get in touch &rarr;
            </a>
          </div>

        </div>
      </article>

      <footer class="py-6 px-4 sm:px-6 border-t border-[#1a1a1a] relative z-10">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2 text-[10px] text-[#555]">
          <p>&copy; 2026 Islam Azzam</p>
          <a href="/" class="hover:text-[#999] transition-colors">Back to home</a>
        </div>
      </footer>

    </AppShell>
  </div>
</Base>
