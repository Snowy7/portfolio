---
import Base from "../layouts/Base.astro";
import { profile, featuredProjects, experience, interests, currentlyDoing } from "../data/portfolio";
import { getCollection } from "astro:content";
import AppShell from "../components/AppShell.vue";
import TypingHero from "../components/TypingHero.vue";
import TimeZone from "../components/TimeZone.vue";

const allPosts = await getCollection("blog");
const blogPosts = allPosts
  .filter((p) => p.data.published)
  .sort((a, b) => {
    const months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    const parse = (d: string) => {
      const [mon, yr] = d.split(" ");
      return parseInt(yr) * 12 + months.indexOf(mon);
    };
    return parse(b.data.date) - parse(a.data.date);
  });
---

<Base
  title="Islam Azzam | Software Developer & Network Engineer"
  description="Islam Azzam — Software Developer & Network Engineer with 8+ years of experience. Building web platforms, multiplayer games, AI tools, and autonomous vehicles."
>
  <div class="min-h-screen bg-black text-[#999] font-plex antialiased selection:bg-green-500/20 selection:text-green-300">
    <AppShell isHome client:only="vue">

      <!-- Hero -->
      <section id="hero" class="pt-20 sm:pt-24 pb-12 sm:pb-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <div class="grid md:grid-cols-[1fr_200px] gap-6 md:gap-8 items-start">
            <div>
              <!-- Mobile: photo + name row -->
              <div class="flex items-center gap-4 mb-4 md:hidden">
                <div data-animate="photo" class="w-16 h-16 rounded-full overflow-hidden border border-[#1a1a1a] shrink-0">
                  <img
                    src="/images/me/linkedin-pfp.png"
                    alt="Islam Azzam"
                    class="w-full h-full object-cover opacity-70 grayscale"
                  />
                </div>
                <h1 data-animate="glitch" class="font-anybody font-800 text-3xl leading-[0.9] tracking-tight text-white">
                  Hey, I'm Islam.
                </h1>
              </div>
              <!-- Desktop: name only (photo is in side column) -->
              <h1 data-animate="glitch" class="hidden md:block font-anybody font-800 text-4xl md:text-5xl leading-[0.9] tracking-tight text-white mb-3">
                Hey, I'm Islam.
              </h1>
              <div data-animate="boot-2"><TypingHero client:only="vue" /></div>
              <p data-animate="boot-3" class="text-sm text-[#888] leading-relaxed max-w-lg mt-6 mb-4">{profile.bio}</p>
              <p data-animate="boot-4" class="text-sm text-[#666] leading-relaxed max-w-lg">{profile.degree} @ {profile.university}. Based in {profile.location}.</p>
              <div data-animate="boot-5" class="flex items-center flex-wrap gap-3 sm:gap-4 mt-8 text-xs">
                <a href={profile.github} class="text-[#666] hover:text-green-400 transition-colors">GitHub</a>
                <span class="text-[#333]">/</span>
                <a href={profile.linkedin} class="text-[#666] hover:text-green-400 transition-colors">LinkedIn</a>
                <span class="text-[#333]">/</span>
                <a href={profile.itch} class="text-[#666] hover:text-green-400 transition-colors">Itch.io</a>
                <span class="text-[#333]">/</span>
                <span class="text-[#555]"><TimeZone client:load /></span>
              </div>
            </div>
            <!-- Desktop photo (side column) -->
            <div data-animate="photo" class="hidden md:block rounded-xl overflow-hidden border border-[#1a1a1a] relative group">
              <img
                src="/images/me/linkedin-pfp.png"
                alt="Islam Azzam"
                class="w-full aspect-[3/4] object-cover opacity-60 grayscale group-hover:opacity-80 group-hover:grayscale-0 transition-all duration-700"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- About: Currently + Interests -->
      <section id="about" class="reveal py-10 sm:py-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-6">
          <div>
            <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-4">Right now</p>
            <div class="space-y-3 text-xs">
              <div class="flex gap-3 py-2 border-b border-[#1a1a1a]">
                <span class="text-[#555] w-16 shrink-0">reading</span>
                <span class="text-[#999]">{currentlyDoing.reading}</span>
              </div>
              <div class="flex gap-3 py-2 border-b border-[#1a1a1a]">
                <span class="text-[#555] w-16 shrink-0">learning</span>
                <span class="text-[#999]">{currentlyDoing.learning}</span>
              </div>
              <div class="flex gap-3 py-2 border-b border-[#1a1a1a]">
                <span class="text-[#555] w-16 shrink-0">building</span>
                <span class="text-[#999]">{currentlyDoing.building}</span>
              </div>
              <div class="flex gap-3 py-2 border-b border-[#1a1a1a]">
                <span class="text-[#555] w-16 shrink-0">playing</span>
                <span class="text-[#999]">{currentlyDoing.listening}</span>
              </div>
            </div>
          </div>
          <div>
            <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-4">Interests</p>
            <div class="flex flex-wrap gap-2">
              {interests.map((i) => (
                <span class="text-[10px] tracking-wider px-2.5 py-1 border border-[#222] text-[#888] hover:border-green-400/30 hover:text-green-400/70 transition-all cursor-default">{i}</span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Featured Projects -->
      <section id="work" class="reveal py-10 sm:py-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <div class="flex items-baseline justify-between mb-6">
            <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50">Selected projects</p>
            <a href="/projects" class="text-[10px] text-green-400/40 hover:text-green-400 transition-colors tracking-wider">VIEW ALL &rarr;</a>
          </div>

          {featuredProjects.slice(0, 4).map((project, i) => (
            <a href={`/projects/${project.slug}`} class="block group">
              <article class="py-5 border-t border-[#1a1a1a] hover:border-[#2a2a2a] transition-colors">
                <div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-5">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 mb-2">
                      <span class="text-[10px] text-green-400/30">0{i + 1}</span>
                      <h3 class="text-sm text-white font-bold group-hover:text-green-400 transition-colors">{project.title}</h3>
                      <span class="text-[9px] text-[#444] tracking-wider uppercase">{project.category}</span>
                    </div>
                    <p class="text-xs text-[#777] leading-relaxed mb-3">{project.description}</p>
                    <div class="flex items-center flex-wrap gap-2">
                      {project.tags.slice(0, 3).map((tag) => (
                        <span class="text-[9px] tracking-wider uppercase text-[#555] px-2 py-0.5 border border-[#222]">{tag}</span>
                      ))}
                      <div class="flex-1"></div>
                      <span class="text-[10px] text-[#444] tracking-wider">{project.status}</span>
                    </div>
                  </div>
                  <div class="hidden md:block overflow-hidden rounded-md shrink-0 w-[200px]">
                    <img src={project.image} alt={project.title} class="w-full aspect-video object-cover opacity-20 grayscale group-hover:opacity-40 group-hover:grayscale-0 transition-all duration-700" loading="lazy" />
                  </div>
                </div>
              </article>
            </a>
          ))}
          <div class="border-t border-[#1a1a1a]"></div>
        </div>
      </section>

      <!-- Blog -->
      <section id="blog" class="reveal py-10 sm:py-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <div class="flex items-baseline justify-between mb-6">
            <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50">Writing</p>
            <a href="/blog" class="text-[10px] text-green-400/40 hover:text-green-400 transition-colors tracking-wider">ALL POSTS &rarr;</a>
          </div>
          <div class="grid sm:grid-cols-2 gap-3">
            {blogPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="block group">
                <article class="p-4 sm:p-5 border border-[#1a1a1a] hover:border-[#2a2a2a] transition-colors rounded-lg h-full">
                  <div class="flex items-center gap-2 text-[10px] text-[#555] mb-2">
                    <span>{post.data.date}</span>
                    <span>&middot;</span>
                    <span>{post.data.readTime}</span>
                  </div>
                  <h3 class="text-xs text-white font-bold mb-1 group-hover:text-green-400 transition-colors">{post.data.title}</h3>
                  <p class="text-[11px] text-[#777] leading-relaxed">{post.data.excerpt}</p>
                </article>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section class="reveal py-10 sm:py-12 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-6">Career</p>
          {experience.map((exp) => (
            <div class="py-4 border-t border-[#1a1a1a] group">
              <div class="flex items-start gap-3">
                {exp.logo ? (
                  <img src={exp.logo} alt={exp.company} class="w-8 h-8 rounded-md object-cover opacity-40 group-hover:opacity-70 transition-opacity shrink-0 mt-0.5" loading="lazy" />
                ) : (
                  <div class="w-8 h-8 rounded-md bg-[#1a1a1a] shrink-0 mt-0.5 flex items-center justify-center text-[10px] text-[#444]">
                    {exp.company.charAt(0)}
                  </div>
                )}
                <div class="flex-1 min-w-0">
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1 gap-1">
                    <h3 class="text-xs text-white font-bold group-hover:text-green-400 transition-colors">{exp.role}</h3>
                    <span class="text-[10px] text-[#555]">{exp.period}</span>
                  </div>
                  <p class="text-[10px] text-green-400/30 mb-1">{exp.company} &middot; {exp.location}</p>
                  <p class="text-[11px] text-[#777] leading-relaxed">{exp.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" class="reveal py-12 sm:py-16 px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto">
          <p class="text-[10px] tracking-[0.3em] uppercase text-green-400/50 mb-4">Say hello</p>
          <h2 class="font-anybody font-800 text-2xl text-white tracking-tight mb-3">
            Let's chat<span class="text-green-400">.</span>
          </h2>
          <p class="text-xs text-[#777] max-w-md mb-6">Projects, collaborations, game jams, or anything else.</p>
          <a href={`mailto:${profile.email}`} class="text-sm text-green-400/70 hover:text-green-400 transition-colors">{profile.email}</a>
        </div>
      </section>

      <footer class="py-6 px-4 sm:px-6 border-t border-[#1a1a1a] relative z-10">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-2 text-[10px] text-[#555]">
          <p>&copy; 2026 Islam Azzam &middot; <span class="text-[#333]">click the logo 5 times</span></p>
          <p class="text-[#333]">Built with Astro + Vue + Tailwind</p>
        </div>
      </footer>

    </AppShell>
  </div>

</Base>
